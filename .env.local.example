# Copy to .env.local and edit. .env.local is gitignored.
# scripts/start-http.sh sources this file before launching the server.

# Bearer token required by clients in the Authorization header.
# Generate one with: openssl rand -hex 32
# (start-http.sh will auto-generate and append one on first run if unset.)
MCP_AUTH_TOKEN=replace-me-with-a-long-random-string

# Transport: stdio (default for Claude Desktop on this Mac) or http (remote access).
MCP_TRANSPORT=http

# HTTP transport settings (only used when MCP_TRANSPORT=http).
MCP_HTTP_PORT=3000
MCP_BIND=0.0.0.0          # 127.0.0.1 for local-only; 0.0.0.0 for LAN/Tailscale
MCP_HTTP_PATH=/mcp

# Server logging: error | warn | info | debug
LOG_LEVEL=info
